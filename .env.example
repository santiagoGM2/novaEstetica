# =====================================================
# Variables de entorno — Nova Estética Premium
# =====================================================
# Copiar a .env.local para desarrollo y configurar las
# mismas variables en Vercel → Settings → Environment
# Variables para producción.

# ----- GoHighLevel (server-side, NO exponer al cliente) -----
# Token de Private Integration. Generar en:
#   Settings → Private Integrations → "Generate token"
# Scopes mínimos: contacts.write, contacts.readonly
GHL_API_KEY=

# ID de la Location (Sub-Account) en GHL.
#   Settings → Business Profile → "Location ID"
GHL_LOCATION_ID=

# ----- WhatsApp (client-side, prefijo VITE_ obligatorio) -----
# Link de WhatsApp oficial para los FABs y el botón de fallback del calendario.
# Formato oficial (recomendado): https://api.whatsapp.com/send/?phone=57XXXXXXXXXX&text&type=phone_number&app_absent=0
VITE_WHATSAPP_LINK=https://api.whatsapp.com/send/?phone=573105725730&text&type=phone_number&app_absent=0
