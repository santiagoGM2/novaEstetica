# =====================================================
# Variables de entorno — Nova Aesthetic Professionals
# =====================================================
# Copiar a .env.local para desarrollo y configurar las
# mismas variables en Vercel → Settings → Environment
# Variables para producción.

# ----- GoHighLevel Inbound Webhook (client-side, prefijo VITE_) -----
# URL del Inbound Webhook del workflow "0 - Captación Quiz Landing" en GHL.
# Obtenerla en:
#   GHL → Automation → Workflows → "0 - Captación Quiz Landing"
#   → trigger "Inbound Webhook" → "Copy URL"
#
# Esta URL se expone al cliente (no contiene secrets — es un endpoint
# público de GHL). El workflow del GHL decide qué hacer con cada payload
# que llega.
#
# Comportamiento si falta esta variable:
#   - En desarrollo (DEV): el quiz entra en modo MOCK
#     (no envía nada, solo console.log).
#   - En producción (PROD): el quiz muestra mensaje de error con
#     fallback a WhatsApp. Hay un console.error claro para el equipo.
VITE_GHL_WEBHOOK_URL=

# ----- WhatsApp (client-side, prefijo VITE_ obligatorio) -----
# Link de WhatsApp oficial para los FABs, el botón de fallback del
# calendario, y el botón de fallback si el webhook falla.
# Formato oficial: https://api.whatsapp.com/send/?phone=57XXXXXXXXXX&text&type=phone_number&app_absent=0
VITE_WHATSAPP_LINK=https://api.whatsapp.com/send/?phone=573105725730&text&type=phone_number&app_absent=0
